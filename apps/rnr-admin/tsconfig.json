{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@admin/*": ["./*"],
      "~/*": ["../../packages/rnr-ui/reusables/*"],
      "@/registry/*": ["../../packages/registry/src/*"]
    },
    "jsxImportSource": "nativewind",
    "jsx": "react-native",
    "types": ["nativewind/types"],
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "incremental": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "index.js",
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "global.d.ts"
  ],
  "exclude": ["node_modules", "build", "dist", ".expo", "../../packages/rnr-ui"]
}