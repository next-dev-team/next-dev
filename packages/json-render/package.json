{
  "name": "@next-dev/json-render",
  "description": "json-render — renders a DesignSpec JSON tree to React components",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist node_modules"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@next-dev/editor-core": "workspace:*"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.1",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
