{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src", "reusables", "*.d.ts"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "~/*": ["reusables/*"],
      "@/rn-uniwind/*": ["src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules"]
}
