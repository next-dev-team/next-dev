{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src", "nativewind-env.d.ts", "global.d.ts"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "~/*": ["reusables/*"],
      "@/rnr-ui/*": ["src/*"],
      "@/registry/*": ["../registry/src/*"]
    },
    "skipLibCheck": true,
    "types": [],
    "lib": ["ES2019"]
  },
  "exclude": ["node_modules", "dist"]
}
