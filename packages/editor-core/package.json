{
  "name": "@next-dev/editor-core",
  "description": "DesignForge document model — spec CRUD, RFC 6902 patches, undo/redo history, selection",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "pnpm --dir ../.. exec vitest run --root packages/editor-core --config vitest.config.ts",
    "test:watch": "pnpm --dir ../.. exec vitest --root packages/editor-core --config vitest.config.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "fast-json-patch": "^3.1.1",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
