{
  "name": "@next-dev/catalog",
  "description": "DesignForge component catalog — maps component types to UniWind components with Zod schemas",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./json-render": {
      "types": "./src/json-render.ts",
      "import": "./src/json-render.ts"
    },
    "./json-render-interop": {
      "types": "./src/json-render-interop.ts",
      "import": "./src/json-render-interop.ts"
    },
    "./json-render-redux": {
      "types": "./src/json-render-redux.ts",
      "import": "./src/json-render-redux.ts"
    },
    "./json-render-registry": {
      "types": "./src/json-render-registry.tsx",
      "import": "./src/json-render-registry.tsx"
    },
    "./json-render-zustand": {
      "types": "./src/json-render-zustand.ts",
      "import": "./src/json-render-zustand.ts"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "import": "./src/registry.ts"
    },
    "./definitions": {
      "types": "./src/definitions.ts",
      "import": "./src/definitions.ts"
    },
    "./code-export": {
      "types": "./src/code-export.ts",
      "import": "./src/code-export.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup src/index.ts src/registry.ts src/definitions.ts src/json-render.ts src/json-render-interop.ts src/json-render-redux.ts src/json-render-registry.tsx src/json-render-zustand.ts src/code-export.ts --format esm --dts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@json-render/codegen": "^0.14.1",
    "@json-render/core": "^0.14.1",
    "@json-render/redux": "^0.14.1",
    "@json-render/react-native": "^0.14.1",
    "@json-render/zustand": "^0.14.1",
    "@next-dev/editor-core": "workspace:*",
    "redux": "^5.0.1",
    "zustand": "^5.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@next-dev/rn-uniwind": "workspace:*",
    "react": "*"
  },
  "peerDependenciesMeta": {
    "@next-dev/rn-uniwind": {
      "optional": true
    }
  }
}
